digraph DynamicKVCache {
    rankdir=TB;
    splines=ortho;
    nodesep=0.35;
    ranksep=0.55;
    fontname="Helvetica";
    fontsize=11;
    labelloc="t";
    label="Dynamic KV Cache (token squares)";

    node [shape=plain fontname="Helvetica"];

    s0 [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD COLSPAN="4" BGCOLOR="#f5f5f5"><B>Step 0</B> (len=1)</TD></TR>
        <TR>
          <TD BGCOLOR="#ffecb3">t0</TD><TD> </TD><TD> </TD><TD> </TD>
        </TR>
      </TABLE>
    >];

    s1 [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD COLSPAN="4" BGCOLOR="#f5f5f5"><B>Step 1</B> (len=2)</TD></TR>
        <TR>
          <TD BGCOLOR="#ffecb3">t0</TD><TD BGCOLOR="#ffecb3">t1</TD><TD> </TD><TD> </TD>
        </TR>
      </TABLE>
    >];

    s2 [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD COLSPAN="4" BGCOLOR="#f5f5f5"><B>Step 2</B> (len=3)</TD></TR>
        <TR>
          <TD BGCOLOR="#ffecb3">t0</TD><TD BGCOLOR="#ffecb3">t1</TD><TD BGCOLOR="#ffecb3">t2</TD><TD> </TD>
        </TR>
      </TABLE>
    >];

    s3 [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD COLSPAN="4" BGCOLOR="#f5f5f5"><B>Step 3</B> (len=4)</TD></TR>
        <TR>
          <TD BGCOLOR="#ffecb3">t0</TD><TD BGCOLOR="#ffecb3">t1</TD><TD BGCOLOR="#ffecb3">t2</TD><TD BGCOLOR="#ffecb3">t3</TD>
        </TR>
      </TABLE>
    >];

    s0 -> s1 [label="realloc + copy old + append" color="#d84315" fontcolor="#bf360c"];
    s1 -> s2 [label="realloc + copy old + append" color="#d84315" fontcolor="#bf360c"];
    s2 -> s3 [label="realloc + copy old + append" color="#d84315" fontcolor="#bf360c"];
}

