digraph PagedKVPrefillFlow {
    rankdir=LR;
    splines=ortho;
    nodesep=0.45;
    ranksep=0.75;
    fontname="Helvetica";
    fontsize=11;
    labelloc="t";
    label="Paged KV Cache Prefill Flow";

    node [shape=plain fontname="Helvetica"];

    logical [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5">
        <TR><TD COLSPAN="4" BGCOLOR="#f5f5f5"><B>Prefill Input Tokens</B></TD></TR>
        <TR>
          <TD BGCOLOR="#c8e6c9">t0</TD>
          <TD BGCOLOR="#c8e6c9">t1</TD>
          <TD BGCOLOR="#c8e6c9">t2</TD>
          <TD BGCOLOR="#c8e6c9">t3</TD>
        </TR>
      </TABLE>
    >];

    table [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5">
        <TR><TD COLSPAN="2" BGCOLOR="#f5f5f5"><B>block_table</B></TD></TR>
        <TR><TD>0</TD><TD>3</TD></TR>
        <TR><TD>1</TD><TD>7</TD></TR>
        <TR><TD>2</TD><TD>2</TD></TR>
        <TR><TD>3</TD><TD>12</TD></TR>
      </TABLE>
    >];

    outloc [shape=box style="rounded,filled" fillcolor="#e8f5e9" color="#558b2f"
        label="Prefill Write Indices\n[3,7,2,12]"];

    store [shape=box style="rounded,filled" fillcolor="#e8f5e9" color="#2e7d32"
        label="Write KV for Prefill Tokens"];

    physical [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5">
        <TR><TD COLSPAN="16" BGCOLOR="#f5f5f5"><B>Physical KV Pool Pages</B></TD></TR>
        <TR>
          <TD>0</TD><TD>1</TD><TD BGCOLOR="#ffe0b2">2</TD><TD BGCOLOR="#ffe0b2">3</TD>
          <TD>4</TD><TD>5</TD><TD>6</TD><TD BGCOLOR="#ffe0b2">7</TD>
          <TD>8</TD><TD>9</TD><TD>10</TD><TD>11</TD>
          <TD BGCOLOR="#ffe0b2">12</TD><TD>13</TD><TD>14</TD><TD>15</TD>
        </TR>
      </TABLE>
    >];

    free [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5">
        <TR><TD BGCOLOR="#f5f5f5"><B>free_slots</B></TD></TR>
        <TR><TD>[0,1,4,5,6,8,9,10,11,13,14,15,...]</TD></TR>
      </TABLE>
    >];

    gather [shape=box style="rounded,filled" fillcolor="#e3f2fd" color="#1565c0"
        label="Gather Full Prefill Context\n[t0,t1,t2,t3]"];

    attn [shape=box style="rounded,filled" fillcolor="#fff3e0" color="#ef6c00"
        label="Prefill Attention"];

    logical -> table [label="map logical -> physical" color="#546e7a" fontcolor="#455a64"];
    table -> outloc [label="select write slice" color="#2e7d32" fontcolor="#2e7d32"];
    outloc -> store [label="indices" color="#2e7d32" fontcolor="#2e7d32"];
    store -> physical [label="write KV pages" color="#2e7d32" fontcolor="#2e7d32"];
    physical -> gather [label="read mapped pages" color="#1565c0" fontcolor="#1565c0"];
    gather -> attn [label="context window" color="#ef6c00" fontcolor="#ef6c00"];
    free -> physical [label="allocate / free pages" color="#546e7a" fontcolor="#455a64"];
}
