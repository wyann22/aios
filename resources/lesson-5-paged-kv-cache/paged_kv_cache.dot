digraph PagedKVCache {
    rankdir=LR;
    splines=ortho;
    nodesep=0.45;
    ranksep=0.75;
    fontname="Helvetica";
    fontsize=11;
    labelloc="t";
    label="Paged KV Cache (token squares + block_table mapping)";

    node [shape=plain fontname="Helvetica"];

    logical [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5">
        <TR><TD COLSPAN="6" BGCOLOR="#f5f5f5"><B>Logical Tokens (request order)</B></TD></TR>
        <TR>
          <TD BGCOLOR="#c8e6c9">t0</TD>
          <TD BGCOLOR="#c8e6c9">t1</TD>
          <TD BGCOLOR="#c8e6c9">t2</TD>
          <TD BGCOLOR="#c8e6c9">t3</TD>
          <TD BGCOLOR="#c8e6c9">n0</TD>
          <TD BGCOLOR="#c8e6c9">n1</TD>
        </TR>
      </TABLE>
    >];

    table [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5">
        <TR><TD COLSPAN="2" BGCOLOR="#f5f5f5"><B>block_table</B></TD></TR>
        <TR><TD>0</TD><TD>3</TD></TR>
        <TR><TD>1</TD><TD>7</TD></TR>
        <TR><TD>2</TD><TD>2</TD></TR>
        <TR><TD>3</TD><TD>12</TD></TR>
        <TR><TD>4</TD><TD>9</TD></TR>
        <TR><TD>5</TD><TD>15</TD></TR>
      </TABLE>
    >];

    physical [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5">
        <TR><TD COLSPAN="16" BGCOLOR="#f5f5f5"><B>Physical KV Pool Pages</B></TD></TR>
        <TR>
          <TD>0</TD><TD>1</TD><TD BGCOLOR="#ffe0b2">2</TD><TD BGCOLOR="#ffe0b2">3</TD>
          <TD>4</TD><TD>5</TD><TD>6</TD><TD BGCOLOR="#ffe0b2">7</TD>
          <TD>8</TD><TD BGCOLOR="#ffe0b2">9</TD><TD>10</TD><TD>11</TD>
          <TD BGCOLOR="#ffe0b2">12</TD><TD>13</TD><TD>14</TD><TD BGCOLOR="#ffe0b2">15</TD>
        </TR>
      </TABLE>
    >];

    free [label=<
      <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5">
        <TR><TD BGCOLOR="#f5f5f5"><B>free_slots</B></TD></TR>
        <TR><TD>[0,1,4,5,6,8,10,11,13,14,...]</TD></TR>
      </TABLE>
    >];

    store_flow [shape=box style="rounded,filled" fillcolor="#e8f5e9" color="#558b2f" label="STORE flow\n1) out_loc = block_table[cached_len:cached_len+seq_len]\n2) MHAKVCache.store_kv(k, v, out_loc)\n3) physical[out_loc] <- (k,v)"];

    load_flow [shape=box style="rounded,filled" fillcolor="#e3f2fd" color="#1565c0" label="LOAD flow\n1) all_locs = block_table[:cached_len+seq_len]\n2) full_k = k_cache[layer][all_locs]\n3) full_v = v_cache[layer][all_locs]"];

    attn [shape=box style="rounded,filled" fillcolor="#fff3e0" color="#ef6c00" label="Attention\nuses (q, full_k, full_v)"];

    logical -> table [label="logical idx -> page idx" color="#546e7a" fontcolor="#455a64"];
    table -> store_flow [label="provide out_loc slice" color="#2e7d32" fontcolor="#2e7d32"];
    store_flow -> physical [label="write kv by out_loc" color="#2e7d32" fontcolor="#2e7d32"];
    table -> load_flow [label="provide all_locs slice" color="#1565c0" fontcolor="#1565c0"];
    physical -> load_flow [label="gather kv by all_locs" color="#1565c0" fontcolor="#1565c0"];
    load_flow -> attn [label="full_k/full_v" color="#ef6c00" fontcolor="#ef6c00"];
    free -> physical [label="allocate/free pages" color="#546e7a" fontcolor="#455a64"];
}
